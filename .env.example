# Copy to .env and fill in for integration tests (npm test).
# Use a test stand and a register with CRUD permissions only.

Z8_URL=https://your-host/request.json
Z8_LOGIN=your-login
Z8_PASSWORD=your-password
Z8_TEST_REQUEST=YourTestRegister

# Optional
# Z8_TEST_LIMIT=5
# Z8_SKIP_INTEGRATION=1
# Z8_TEST_CREATE_DATA=[{"recordId":"00000000-0000-0000-0000-000000000000"}]
